# ===========================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE
# ===========================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA comite o arquivo .env com credenciais reais!

# Supabase Configuration
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: API Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# Optional: backend API base URL for migration
# When VITE_BACKEND_API_URL is configured, the frontend now prefers backend-first
# routing for supported domains by default. Set any VITE_USE_BACKEND_* flag to
# false only as a temporary compatibility fallback during migration.
VITE_BACKEND_API_URL=
VITE_DISABLE_LEGACY_SUPABASE_ADMIN_FLOW=false
VITE_USE_BACKEND_ADMIN_USERS=
VITE_USE_BACKEND_ACTIONS=
VITE_USE_BACKEND_REQUESTS=
VITE_USE_BACKEND_ANNOUNCEMENTS=
VITE_USE_BACKEND_COMMENTS=
VITE_USE_BACKEND_AUTH_PROFILE=
VITE_USE_BACKEND_TAGS=
VITE_USE_BACKEND_TEAMS=
VITE_USE_BACKEND_OBJECTIVES_ACTIVITIES=
VITE_USE_BACKEND_AUTH_SESSION=
VITE_DISABLE_UNSUPPORTED_HUB_MODULES=
VITE_ALLOW_UNSUPPORTED_HUB_MODULES=false
VITE_SUPABASE_SESSION_STORAGE=session

# Optional: frontend observability beacon endpoint
VITE_OBSERVABILITY_BEACON_URL=
